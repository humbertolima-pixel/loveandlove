# Supabase — pegue em Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Cakto — webhook secret configurado no painel da Cakto
CAKTO_WEBHOOK_SECRET=

# Resend — para envio do email com o link de criação (resend.com)
RESEND_API_KEY=

# Anthropic — usada para organizar a história livre do casal em
# seções estruturadas e gerar a declaração única (console.anthropic.com > API Keys)
ANTHROPIC_API_KEY=

# YouTube Data API v3 — usada para a busca de música dentro do site
# (console.cloud.google.com > APIs e Serviços > Credenciais).
# Gratuita até 100 buscas/dia; sem essa chave, o formulário cai
# automaticamente no botão "abrir YouTube em nova aba".
YOUTUBE_API_KEY=

# URL pública do site (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://loveandlove.com.br

# Meta Pixel (Facebook/Instagram Ads) — Gerenciador de Eventos do Meta.
# NEXT_PUBLIC_META_PIXEL_ID é o ID numérico do pixel (visível no código
# do pixel, ou em Configurações do conjunto de dados).
NEXT_PUBLIC_META_PIXEL_ID=

# META_CONVERSIONS_API_TOKEN é o token de acesso da Conversions API
# (Gerenciador de Eventos > seu Pixel > API de Conversões > gerar
# token de acesso manualmente). Usado pelo servidor para enviar o
# evento de Purchase quando o webhook da Cakto confirma um pagamento —
# mais confiável que depender só do pixel no navegador do cliente.
META_CONVERSIONS_API_TOKEN=
